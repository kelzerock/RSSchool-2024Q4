  "main": "index.js",
  "scripts": {
    "build:prod": "webpack --env mode=production",
    "build:dev": "webpack --env mode=development",
    "start": "webpack serve --env mode=development --env port=3000",
    "prepare": "cd .. && husky decision-making-tool/.husky",
    "lint:fix": "eslint --fix",
