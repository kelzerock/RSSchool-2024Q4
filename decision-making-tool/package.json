    "commitlint": "commitlint --edit",
    "stylelint": "npx stylelint '**/*.css'"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write",
      "npm run stylelint"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/webpack": "^5.28.5",
    "@types/webpack-dev-server": "^4.7.1",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-unicorn": "^57.0.0",
    "file-loader": "^6.2.0",
    "globals": "^16.0.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "postcss": "^8.5.3",
